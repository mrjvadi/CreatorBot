POSTGRES_DSN=postgres://botuser:pass@localhost:5434/license?sslmode=disable

NATS_URL=nats://localhost:4222
NATS_USERNAME=nats
NATS_PASSWORD=nats_secret

# باید دقیقاً با SERVICE_HMAC_SECRET در botpay/.env و botmanager/.env یکسان باشد.
SERVICE_HMAC_SECRET=

# راز مجزا برای امضای JWT توکن لایسنس — با `openssl rand -hex 32` بسازید.
LICENSE_SIGNING_SECRET=

# اختیاری — لایسنسِ تستیِ سراسری: اگر مقدار داده شود، هر bot instance که
# دقیقاً همین مقدار را در LICENSE_TOKEN بفرستد تأیید می‌شود (بدون نیاز به
# license.issue واقعی، برای هر BotID دلخواه). پیش‌فرض خالی = غیرفعال.
# ⚠️ این حفاظتِ ضدِ کپی/کلون را برای هر instance ای که این مقدار را داشته
# باشد دور می‌زند — فقط در محیط تست/dev فعال کنید، هرگز در deploymentی که
# مشتری واقعی هم دارد؛ مثل بقیه‌ی secretها rotate کنید. یک secret نباید هرگز
# جای دیگری هم استفاده/کپی شود (حتی در فایل .env.example یک سرویس دیگر).
TEST_LICENSE_SECRET=

METRICS_PORT=:9097