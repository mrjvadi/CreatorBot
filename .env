# ══════════════════════════════════════════════════════════════
#  متغیرهای مخصوص هر ربات کاربر (هنگام deploy توسط agentmanager
#  به‌صورت خودکار ست می‌شوند — اینجا فقط برای اجرای دستی لازم‌اند)
# ══════════════════════════════════════════════════════════════
# CHANNEL_ID=
# PANEL_TYPE=marzban           # marzban|marzneshin|hiddify|xui
# PANEL_URL=
# PANEL_USERNAME=
# PANEL_PASSWORD=
# PAYMENT_GATEWAY=card         # zarinpal|nowpayments|card
# ZARINPAL_MERCHANT=
# NOWPAYMENTS_KEY=
# CARD_NUMBER=
# CARD_OWNER=

# ─── اختیاری ──────────────────────────────────────────────────
# LOCAL_BOT_API: اگر از Local Bot API Server استفاده می‌کنید (برای فایل >50MB)
# LOCAL_BOT_API=http://telegram-bot-api:8081
# API_SECRET: کلید احراز داخلی برخی سرویس‌ها
# API_SECRET=

# ─── source-service (اختیاری — نیاز به gotd/td) ───────────────
# این سرویس stub است و برای forward از کانال منبع با UserBot API است.
# TG_APP_ID=
# TG_APP_HASH=
# TG_PHONE=
# TG_SESSION_FILE=/data/session.json
# TG_SOURCE_CHANNEL=
# TG_DELIVERY_CHANNEL=
