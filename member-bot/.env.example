APP_ENV=development
BOT_SERVICE_NAME=Member Bot
BOT_TOKEN=
OWNER_ID=0
LOCAL_BOT_API=
# (۲۰۲۶-۰۷-۱۷) این ربات هیچ Postgres ندارد؛ همه‌ی داده روی MongoDB است —
# دیتابیس اختصاصیِ این نوع سرویس member_bot نام دارد.
MONGO_URI=mongodb://mongouser:secret@mongodb:27017/member_bot?authSource=admin
MONGO_DB=member_bot
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

NATS_URL=nats://localhost:4222
NATS_USERNAME=nats
NATS_PASSWORD=change_me
# اگر خالی بماند، این ربات "عمداً آفلاین" فرض می‌شود و همه‌ی قابلیت‌های
# متکی به NATS (member.check responder، license check-in، رویدادهای
# membership.joined/left) بی‌صدا خاموش می‌مانند.

LOCK_API_PORT=8081
# ⚠️ خالی‌گذاشتن این مقدار یعنی Lock HTTP API بدون احراز هویت واقعی اجرا
# می‌شود (apiKey خالی == درخواست بدون هدر X-API-Key هم رد می‌شود، fail-open).
LOCK_API_SECRET=change_me_strong_secret
ENCRYPTION_KEY=

# polling = ربات خودش آپدیت‌ها را می‌گیرد | webhook = از طریق GATEWAY_URL
BOT_MODE=polling
GATEWAY_URL=

# توکن ضدکپی/ضدکلون — در deploy واقعی توسط botmanager تزریق می‌شود.
LICENSE_TOKEN=
# شناسه‌ی سرور (UUID) — در deploy واقعی توسط agentmanager تزریق می‌شود.
SERVER_ID=

FRAUD_ENGINE_URL=
