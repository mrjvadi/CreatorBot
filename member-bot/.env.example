BOT_TOKEN=
# (۲۰۲۶-۰۷-۰۶) رفع دو مشکل: (۱) نام env اشتباه بود — کد واقعی
# (member-bot/cmd/bot/main.go) این را با نام MASTER_DSN می‌خواند، نه
# POSTGRES_DSN؛ (۲) کاربر/دیتابیسِ "memberbot" ساختگی بود — کاربر واقعی
# همیشه botuser است و دیتابیس اختصاصیِ این نوع سرویس member_bot نام دارد
# (رجوع deploy/init-db.sql).
MASTER_DSN=postgres://botuser:secret@postgres:5432/member_bot?sslmode=disable
POSTGRES_PASSWORD=secret
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
LOCK_API_PORT=8081
LOCK_API_SECRET=change_me_strong_secret
ENCRYPTION_KEY=
