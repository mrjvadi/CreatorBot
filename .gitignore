# همه‌ی فایل‌های .env حاوی secret هستند — از ۲۰۲۶-۰۷-۱۴ هیچ .env در git ردیابی
# نمی‌شود؛ فقط .env.example (بدون secret) tracked است. رجوع SECRETS_ROTATION.md.
**/.env
!**/.env.example

# env پایه‌ی سرور — secret واقعی، روی هر سرور جدا ساخته می‌شود (رجوع
# agentmanager/.env کلید BOT_BASE_ENV_FILE).
agentmanager/botenv.env
agentmanager/botenv/

# خروجی اجرای محلی run.sh
.logs/
.run.pids

# باینری‌ها و artifact های build
tools/e2e-provision/e2e-provision
/e2e-provision
ads-bot/e2e-lockrental
*.tar
*.orig
*.tmp.*
.gotmp/
graphify-out
graphify-out/
plans/
prog/*
test/
.log/

# فایل‌های ادیتور/IDE
.idea/
.vscode/
.agents/
.claude/

# Go — کاورج و باینریِ تست
*.test
coverage.out
coverage.txt

# apimanager/web (Vite/TS) — artifact های build؛ node_modules خودش یک
# .gitignore مجزا در همان پوشه دارد.
apimanager/web/vite.config.js
apimanager/web/vite.config.d.ts
*.tsbuildinfo
