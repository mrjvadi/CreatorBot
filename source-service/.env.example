# (۲۰۲۶-۰۷-۰۶) کاربر/دیتابیسِ "sourceservice" ساختگی بود — کاربر واقعی
# همیشه botuser است و دیتابیس اختصاصیِ این سرویس source_svc نام دارد
# (رجوع deploy/init-db.sql؛ نام مطابقت‌دار عمداً source_svc نه source_service
# چون همان‌جا از ابتدا این‌طور تعریف شده بود).
POSTGRES_DSN=postgres://botuser:secret@postgres:5432/source_svc?sslmode=disable
POSTGRES_PASSWORD=secret
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
NATS_URL=nats://nats:4222

# Identifies this instance to botmanager. botmanager activates the license
# and hands back a worker ID + the Telegram account (app id/hash/phone,
# session encryption key) to run as — see README "معماری worker". Give
# every instance its own key.
LICENSE_KEY=

# Only used by `cmd/login --postgres-dsn ... --session-key ...` when you're
# NOT letting botmanager supply the session key (e.g. bootstrapping before
# botmanager exists, or manual recovery). Generate one with
# `go run ./cmd/login --gen-key`. Real workers get this from botmanager, not
# from this env var.
SESSION_ENCRYPTION_KEY=

# Only used by `cmd/login --file` (plain local file instead of the database
# — offline testing only).
SESSIONS_DIR=/app/sessions
