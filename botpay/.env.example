APP_ENV=development
BOT_SERVICE_NAME=BotPay
BOT_TOKEN=
OWNER_ID=
LOCAL_BOT_API=

# DEFAULT_LANG زبان پیش‌فرض ربات (fa یا en) وقتی کاربر هنوز انتخاب نکرده
DEFAULT_LANG=fa

POSTGRES_DSN=postgres://botuser:pass@localhost:5434/botpay?sslmode=disable

NATS_URL=nats://localhost:4222
NATS_USERNAME=nats
NATS_PASSWORD=nats_secret

# Redis (اختیاری) — برای cache موجودی
REDIS_ADDR=
REDIS_PASSWORD=
REDIS_DB=0

# TON — یه آدرس مشترک برای دریافت همه پرداخت‌ها
TON_MASTER_ADDRESS=UQD...your_wallet_address
TON_API_KEY=
TON_NETWORK=mainnet
CONSENSUS_DB_DIR=./data/consensus

# نکته: ارتباط بین‌سرویسی فقط از طریق NATS (pay.*) است؛ REST API حذف شده.

# راز مادر HMAC برای اعتبارسنجی service_key در PayRequest — باید دقیقاً در
# botpay و در هر سرویس مرکزی که pay.* صدا می‌زند (botmanager, ads-bot, ...)
# یکسان باشد. فقط به سرویس‌های مرکزی مورد اعتماد بدهید — هرگز به container
# ربات‌های مشتری. بدون این مقدار botpay همه‌ی درخواست‌های pay.* را رد می‌کند.
SERVICE_HMAC_SECRET=
