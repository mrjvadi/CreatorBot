APP_ENV=development
BOT_SERVICE_NAME=VPN Bot
BOT_TOKEN=
OWNER_ID=0
CHANNEL_ID=0
LOCAL_BOT_API=
# (۲۰۲۶-۰۷-۱۷) این ربات هیچ Postgres ندارد؛ همه‌ی داده روی MongoDB است —
# دیتابیس اختصاصیِ این نوع سرویس vpn_bot نام دارد.
MONGO_URI=mongodb://mongouser:secret@mongodb:27017/vpn_bot?authSource=admin
MONGO_DB=vpn_bot
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

NATS_URL=nats://localhost:4222
NATS_USERNAME=nats
NATS_PASSWORD=change_me

PANEL_TYPE=marzban
PANEL_URL=https://panel.example.com
PANEL_USERNAME=admin
PANEL_PASSWORD=
PAYMENT_GATEWAY=zarinpal
ZARINPAL_MERCHANT=
NOWPAYMENTS_KEY=
CARD_NUMBER=
CARD_OWNER=

ENCRYPTION_KEY=

# polling = ربات خودش آپدیت‌ها را می‌گیرد | webhook = از طریق GATEWAY_URL
BOT_MODE=polling
GATEWAY_URL=

# شناسه‌ی سرور (UUID) — در deploy واقعی توسط agentmanager تزریق می‌شود
SERVER_ID=
# توکن ضدکپی/ضدکلون — fail-closed (بدون این، سرویس اصلاً بالا نمی‌آید).
# در deploy واقعی توسط botmanager تزریق می‌شود.
LICENSE_TOKEN=
