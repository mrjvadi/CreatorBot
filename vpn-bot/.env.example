BOT_TOKEN=
CHANNEL_ID=0
# (۲۰۲۶-۰۷-۰۶) رفع دو مشکل: (۱) نام env اشتباه بود — کد واقعی
# (vpn-bot/cmd/bot/main.go) این را با نام MASTER_DSN می‌خواند، نه POSTGRES_DSN؛
# (۲) کاربر/دیتابیسِ "vpnbot" ساختگی بود — کاربر واقعی همیشه botuser است و
# دیتابیس اختصاصیِ این نوع سرویس vpn_bot نام دارد (رجوع deploy/init-db.sql).
MASTER_DSN=postgres://botuser:secret@postgres:5432/vpn_bot?sslmode=disable
POSTGRES_PASSWORD=secret
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
PANEL_TYPE=marzban
PANEL_URL=https://panel.example.com
PANEL_USERNAME=admin
PANEL_PASSWORD=
PAYMENT_GATEWAY=zarinpal
ZARINPAL_MERCHANT=
NOWPAYMENTS_KEY=
CARD_NUMBER=
CARD_OWNER=
