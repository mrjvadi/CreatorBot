MONGO_URI=mongodb://mongouser:pass@localhost:27017/creatorbot?authSource=admin
MONGO_DB=creatorbot

NATS_URL=nats://localhost:4222
NATS_USERNAME=nats
NATS_PASSWORD=nats_secret

# تلگرام — اختیاری. برای فعال‌سازی هشدار، هر دو باید ست شوند و CHAT_ID باید
# شناسه‌ی یک سوپرگروه با «Topics» فعال باشد (تنظیمات گروه → Topics → روشن).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
LOCAL_BOT_API=
MIN_TELEGRAM_LEVEL=warn

# کلید API برای GET /logs — با `openssl rand -hex 24` بسازید.
LOG_API_KEY=

PORT=8099
