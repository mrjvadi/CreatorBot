PORT=8090
# الزامی — سرویس با log.Fatal بالا نمی‌آید اگر خالی باشد.
INTERNAL_KEY=change_me_internal_key

NATS_URL=nats://localhost:4222
NATS_USERNAME=nats
NATS_PASSWORD=change_me

# bot های ثابت — از BotFather بگیر
BOTMANAGER_TOKEN=123456:AA-your-bot-token-here
BOTMANAGER_BOT_ID=123456
BOTPAY_TOKEN=123456:AA-your-bot-token-here
BOTPAY_BOT_ID=123456

# HMAC برای اعتبارسنجی gateway.register از NATS — الزامی (کد با log.Fatal
# بالا نمی‌آید اگر خالی باشد). باید دقیقاً با SERVICE_HMAC_SECRET در بقیه‌ی
# سرویس‌های مرکزی یکسان باشد.
SERVICE_HMAC_SECRET=change_me_shared_platform_hmac_secret
