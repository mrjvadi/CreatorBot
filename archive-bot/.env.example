BOT_TOKEN=
CHANNEL_ID=0
# (۲۰۲۶-۰۷-۰۶) "app"/"secret" کاربر واقعی این پروژه نیست — کاربر واقعیِ
# مشترک همه‌ی سرویس‌ها روی این Postgres همیشه botuser است؛ دیتابیس هم
# اختصاصیِ نوع سرویس archive-bot است (رجوع deploy/init-db.sql).
POSTGRES_DSN=postgres://botuser:secret@postgres:5432/archive_bot?sslmode=disable
POSTGRES_PASSWORD=secret
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
