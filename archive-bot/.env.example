APP_ENV=development
BOT_SERVICE_NAME=Archive Bot
BOT_TOKEN=
OWNER_ID=0
CHANNEL_ID=0
LOCAL_BOT_API=
# (۲۰۲۶-۰۷-۱۷) این ربات هیچ Postgres ندارد؛ همه‌ی داده روی MongoDB است —
# دیتابیس اختصاصیِ این نوع سرویس archive_bot نام دارد.
MONGO_URI=mongodb://mongouser:secret@mongodb:27017/archive_bot?authSource=admin
MONGO_DB=archive_bot
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

NATS_URL=nats://localhost:4222
NATS_USERNAME=nats
NATS_PASSWORD=change_me

# polling = ربات خودش آپدیت‌ها را می‌گیرد | webhook = از طریق GATEWAY_URL
BOT_MODE=polling
GATEWAY_URL=

# شناسه‌ی سرور (UUID) — در deploy واقعی توسط agentmanager تزریق می‌شود
SERVER_ID=
# توکن ضدکپی/ضدکلون — در deploy واقعی توسط botmanager هنگام ساخت instance
# تزریق می‌شود؛ بدون این توکن ربات بالا نمی‌آید (fail-closed).
LICENSE_TOKEN=
