# ============================================================
# CreatorBot — Environment Template (master, فقط برای docker-compose ریشه‌ی
# این پوشه؛ برای هر سرویس اجرا کنید: bash deploy/setup.sh)
#
# (۲۰۲۶-۰۷-۰۶) این فایل بازطراحی شد: از این به بعد فقط شامل متغیرهایی است که
# واقعاً در deploy/docker-compose.yml با ${VAR} جایگزین می‌شوند (رمزهای
# زیرساخت مشترک + دامنه). رمزهای مخصوص هر سرویس (BOT_TOKEN, JWT_*,
# SERVICE_HMAC_SECRET, ADMIN_KEY های مختلف, ...) دیگر این‌جا تکرار نمی‌شوند —
# هرکدام از env_file مخصوص خودِ همان سرویس (مثل ../botpay/.env) خوانده
# می‌شوند تا وقتی سرویس جدیدی اضافه شود، این فایل مرکزی رشد نامحدود نکند.
# MASTER_DSN/UPLOADER_DSN/VPN_DSN/... قدیمی هم حذف شدند — چون هرکدام حالا
# مستقیم داخل environment: خودِ همان سرویس در docker-compose.yml ساخته
# می‌شوند (از روی همین POSTGRES_PASSWORD + اسم دیتابیس اختصاصی، رجوع
# migrations/000_create_databases.sql و 000_create_product_databases.sql).
# ============================================================

# ===== Domain =====
DOMAIN=example.com
ACME_EMAIL=your@email.com

# ===== Database =====
POSTGRES_PASSWORD=generated_by_setup
POSTGRES_PORT=5434

# ===== Redis =====
REDIS_PASSWORD=generated_by_setup
REDIS_PORT=6381

# ===== MongoDB =====
MONGO_USER=mongouser
MONGO_PASSWORD=generated_by_setup
MONGO_DB=creatorbot
MONGO_PORT=27017

# ===== NATS =====
NATS_USERNAME=nats
NATS_PASSWORD=generated_by_setup
NATS_PORT=4222

# ===== apimanager (Traefik routing + خودِ سرویس) =====
API_PORT=8086

# ===== member-bot (Lock API — پورت انتشاریافته روی هاست) =====
LOCK_API_PORT=8082

# ===== Grafana =====
GRAFANA_PASSWORD=generated_by_setup

# ------------------------------------------------------------
# هرچیز دیگری (BOT_TOKEN، JWT_ACCESS_SECRET/JWT_REFRESH_SECRET، ENCRYPTION_KEY،
# SERVICE_HMAC_SECRET، LICENSE_SIGNING_SECRET، IMAGE_REGISTRY_ADMIN_KEY،
# PANEL_URL/PANEL_TOKEN، PAYMENT_GATEWAY، SERVER_ID، TG_APP_ID/TG_APP_HASH و
# غیره) داخل env_file مخصوصِ همان سرویس تنظیم می‌شود (مثلاً botmanager/.env،
# vpn-bot/.env، source-service/.env، ...) — نه این‌جا. رجوع docker-compose.yml
# همین پوشه برای اینکه هر سرویس دقیقاً کدام env_file را می‌خواند.
# ------------------------------------------------------------
