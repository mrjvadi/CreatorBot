APP_ENV=development
BOT_SERVICE_NAME=Uploader Bot
BOT_TOKEN=123456:AA-your-bot-token-here
OWNER_ID=0
CHANNEL_ID=0

# DB — این ربات هیچ Postgres ندارد؛ همه‌ی داده روی MongoDB است (دیتابیس
# اختصاصیِ نوع سرویس uploader-bot، نه botmanager) — چند instance می‌توانند
# این را با ستون instance_id شریک شوند.
MONGO_URI=mongodb://mongouser:pass@localhost:27017/creatorbot?authSource=admin
MONGO_DB=creatorbot
REDIS_ADDR=localhost:6381
REDIS_PASSWORD=
REDIS_DB=0

NATS_URL=nats://localhost:4222
NATS_USERNAME=nats
NATS_PASSWORD=change_me
SERVER_ID=
HEARTBEAT_INTERVAL_SEC=30

LOCAL_BOT_API=

# polling = ربات خودش آپدیت‌ها را می‌گیرد | webhook = از طریق GATEWAY_URL
BOT_MODE=polling
GATEWAY_URL=

# باید با ENCRYPTION_KEY در botmanager/.env و بقیه‌ی سرویس‌های مرکزی یکسان
# باشد — برای رمزنگاری BotToken قفل‌های نوع «ربات» قبل از ذخیره در Mongo.
ENCRYPTION_KEY=generate_with_openssl_rand_hex_32

# توکن ضدکپی/ضدکلون — در deploy واقعی توسط botmanager تزریق می‌شود. برای
# dev/test محلی می‌توانید همان مقدار TEST_LICENSE_SECRET سرویس license-service
# را این‌جا بگذارید (رجوع license-service/.env.example) تا بدون license.issue
# واقعی بالا بیاید.
LICENSE_TOKEN=
