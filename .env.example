# فقط متغیرهایی که واقعاً با ${VAR} در docker-compose.yml همین پوشه
# جایگزین می‌شوند این‌جا هستند — رمزهای مخصوص هر سرویس (BOT_TOKEN, JWT_*,
# SERVICE_HMAC_SECRET, ADMIN_KEY های مختلف, ...) در .env همان سرویس هستند
# (مثل botmanager/.env)، نه این‌جا.

# ── Database ──────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password

# ── MongoDB ───────────────────────────────────────────────
MONGO_PASSWORD=change_me_strong_password

# ── Redis ─────────────────────────────────────────────────
REDIS_PASSWORD=change_me_strong_password

# ── NATS ──────────────────────────────────────────────────
NATS_USERNAME=nats
NATS_PASSWORD=change_me_strong_password

# ── Grafana ───────────────────────────────────────────────
# خالی‌گذاشتن یعنی سقوط بی‌صدا به پیش‌فرض ناامنِ "admin".
GRAFANA_PASSWORD=change_me_strong_password
