# ── admanager-bot — نمونه‌ی تنظیمات ──────────────────────────────
APP_ENV=development
BOT_SERVICE_NAME=Ad Manager Bot
# این فایل را به .env کپی کنید و مقادیر را پر کنید.
# (کلیدها دقیقاً همان فیلدهای Config در cmd/bot/main.go هستند.)

# توکن ربات از BotFather
BOT_TOKEN=123456:AA-your-bot-token-here
# آیدی عددی تلگرام مدیر (تنها کسی که به ربات دسترسی دارد)
OWNER_ID=0
# آدرس Local Bot API (اختیاری؛ خالی = استفاده از سرور رسمی تلگرام)
LOCAL_BOT_API=

# ── MongoDB (داده‌ی هر ربات با instance_id ایزوله می‌شود) ─────────
MONGO_URI=mongodb://mongouser:pass@localhost:27017/creatorbot?authSource=admin
MONGO_DB=creatorbot

# ── Redis (فقط کش و state machine کاربر) ─────────────────────────
REDIS_ADDR=localhost:6381
REDIS_PASSWORD=
REDIS_DB=0

# ── NATS (heartbeat و رویدادها) ──────────────────────────────────
NATS_URL=nats://localhost:4222
NATS_USERNAME=
NATS_PASSWORD=

# ── حالت دریافت آپدیت ────────────────────────────────────────────
# polling = ربات خودش آپدیت‌ها را می‌گیرد | webhook = از طریق GATEWAY_URL
BOT_MODE=polling
GATEWAY_URL=

# شناسه‌ی سرور (UUID) برای heartbeat
SERVER_ID=
HEARTBEAT_INTERVAL_SEC=30
