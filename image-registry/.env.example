POSTGRES_DSN=postgres://botuser:pass@localhost:5434/imageregistry?sslmode=disable
PORT=8100

# مسیر ذخیره‌ی فایل‌های واقعی image (خروجی `docker save`) روی دیسک این
# سرویس. در production باید یک volume پایدار (نه دیسک موقت کانتینر) روی این
# مسیر mount شود، وگرنه با هر redeploy فایل‌ها پاک می‌شوند.
IMAGE_STORAGE_DIR=/data/images

# سقف اندازه‌ی فایل قابل‌آپلود (مگابایت). خالی/۰ یعنی پیش‌فرض ۸۱۹۲ (۸ گیگابایت)
# اعمال می‌شود؛ برای خاموش کردن کامل سقف، صریحاً یک عدد منفی بگذارید.
MAX_IMAGE_FILE_SIZE_MB=8192

# کلید مدیریت callerها (X-Admin-Key) — با `openssl rand -hex 24` بسازید.
ADMIN_KEY=

# اختیاری — اگر پر شود و جدول callerها خالی باشد، یک caller اولیه با
# CanWrite=true ساخته می‌شود (مثلاً IP/CIDR ماشین ادمین شما).
SEED_CALLER_CIDR=
SEED_CALLER_LABEL=seed-admin

NATS_URL=nats://localhost:4222
NATS_USERNAME=nats
NATS_PASSWORD=nats_secret
