APP_ENV=development
BOT_SERVICE_NAME=CreatorBot Manager
BOT_TOKEN=123456:AA-your-bot-token-here
OWNER_ID=0

# Local Bot API Server (اختیاری)
LOCAL_BOT_API=

POSTGRES_DSN=postgres://botuser:change_me_strong_password@127.0.0.1:5434/botmanager?sslmode=disable

REDIS_ADDR=localhost:6381
REDIS_PASSWORD=change_me_strong_password
REDIS_DB=0

NATS_URL=nats://localhost:4222
NATS_USERNAME=nats
NATS_PASSWORD=change_me_strong_password

# openssl rand -hex 32
ENCRYPTION_KEY=generate_with_openssl_rand_hex_32

# TON Payment
TON_WALLET_ADDRESS=
TON_API_KEY=
TON_NETWORK=mainnet

# BotPay — اتصال به سرویس کیف پول
BOTPAY_URL=http://localhost:8087
BOTPAY_API_KEY=change_me_shared_with_botpay
BOTPAY_SERVICE_ID=botmanager

# راز مشترک HMAC پلتفرم — باید دقیقاً با SERVICE_HMAC_SECRET در بقیه‌ی
# سرویس‌های مرکزی (agentmanager, apimanager, botpay, ads-bot, ...) یکسان باشد.
SERVICE_HMAC_SECRET=change_me_shared_platform_hmac_secret
