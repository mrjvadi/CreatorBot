POSTGRES_DSN=postgres://botuser:change_me_strong_password@127.0.0.1:5434/botmanager?sslmode=disable

API_PORT=8086

NATS_URL=nats://localhost:4222
NATS_USERNAME=nats
NATS_PASSWORD=change_me_strong_password

JWT_ACCESS_SECRET=change_me_32chars_access_secret!!
JWT_REFRESH_SECRET=change_me_32chars_refresh_secret!

# openssl rand -hex 32
ENCRYPTION_KEY=generate_with_openssl_rand_hex_32

# کلید مشترک با agentmanager — باید در هر دو .env یکسان باشد
AGENT_API_KEY=change_me_shared_with_agentmanager

BOT_TOKEN=123456:AA-your-bot-token-here
LOCAL_BOT_API=

# سرویس جدا برای مدیریت/آپلود ایمیج‌های Docker (جایگزین whitelist قدیمی داخل agentmanager).
# اگر خالی بماند، صفحه‌ی «ایمیج‌ها» در پنل ادمین 503 می‌دهد.
IMAGE_REGISTRY_URL=http://localhost:8100
IMAGE_REGISTRY_ADMIN_KEY=change_me_admin_key

# راز مشترک HMAC پلتفرم — باید دقیقاً با SERVICE_HMAC_SECRET در سایر سرویس‌های
# مرکزی (agentmanager, botmanager, botpay, ...) یکسان باشد.
SERVICE_HMAC_SECRET=change_me_shared_platform_hmac_secret

# ── فقط برای apimanager/deploy/docker-compose.yml (استک مستقل/توسعه) ──
# این دو فقط توسط آن compose جدا مصرف می‌شوند (Postgres/Centrifugo بسته‌شده‌ی
# همان استک)، نه توسط خودِ برنامه‌ی Go — اگر از این compose استفاده نمی‌کنید
# لازم نیست پر شوند.
POSTGRES_PASSWORD=change_me_strong_password
# Centrifugo (فقط برای آن استک مستقل — خود apimanager مستقیماً NATS استفاده
# می‌کند و هیچ کد Go ای این را نمی‌خواند)
CENTRIFUGO_API_KEY=change_me_centrifugo_api_key
