# آدرس پایه‌ی API سرویس apimanager (بدون اسلش انتهایی)
VITE_API_BASE_URL=http://localhost:8080

# یوزرنیم ربات تلگرام پلتفرم که برای Telegram Login Widget استفاده می‌شود
# (باید همان BOT_TOKEN تنظیم‌شده در apimanager باشد و در BotFather دامنه‌ی
# این وب‌سایت به آن ربات متصل شده باشد: /setdomain)
VITE_TELEGRAM_BOT_USERNAME=your_bot_username

# اگر روی true باشد، فرم «ورود آزمایشی» هم در صفحه‌ی لاگین نشان داده می‌شود — راهی برای ورود
# بدون نیاز به ثبت دامنه در BotFather (امضای HMAC در خودِ مرورگر و با توکن ربات ساخته می‌شود،
# توکن هرگز به سرور فرستاده نمی‌شود). در dev server (`npm run dev`) همیشه فعال است؛ این فلگ فقط
# برای فعال‌کردنش در یک build نهایی لازم است — در production واقعی روشنش نکنید.
VITE_ENABLE_DEV_LOGIN=false
