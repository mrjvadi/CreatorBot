# UUID این سرور در جدول servers دیتابیس botmanager
SERVER_ID=90be2689-1105-4dab-861e-db0c8546de10

# آدرس apimanager برای گرفتن JWT
API_MANAGER_URL=http://localhost:8086

# کلید مشترک با apimanager — باید در هر دو .env یکسان باشد
AGENT_API_KEY=4c463e3f992d27783b44e36d6d2fd5ea

# Centrifugo HTTP API — برای publish heartbeat و نتیجه دستورات
CENTRIFUGO_URL=http://localhost:8001/api
CENTRIFUGO_API_KEY=4c463e3f992d27783b44e36d6d2fd5ea

# Centrifugo WebSocket — برای دریافت دستورات Docker
CENTRIFUGO_WS_ENDPOINT=ws://localhost:8001/connection/websocket

HEARTBEAT_INTERVAL_SEC=5

# ── امنیت و محدودیت منابع container ها ──
# whitelist اجباری: فقط image هایی با این prefix ها اجازه‌ی اجرا دارند (جداشده با کاما).
# خالی = هیچ deploy ای مجاز نیست. هیچ image ای از اینترنت pull نمی‌شود.
ALLOWED_IMAGES=creatorbot/,registry.local/creatorbot/
DEFAULT_MEMORY_MB=512
DEFAULT_CPUS=1.0
DEFAULT_PIDS_LIMIT=256
READONLY_ROOTFS=true
DEFAULT_TMPFS_MB=64
