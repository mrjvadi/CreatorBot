# UUID این سرور در جدول servers دیتابیس botmanager
SERVER_ID=00000000-0000-0000-0000-000000000000

# ⚠️ این مقادیر باید با NATS_USERNAME/NATS_PASSWORD در تنظیمات ریشه‌ی
# سرویس‌های دیگر (apimanager/botmanager/...) یکی بمانند.
# نکته: در اجرای docker-compose، این سه خط توسط environment: در
# deploy/docker-compose.yml override می‌شوند — فقط برای اجرای محلی/مستقیم لازم‌اند.
NATS_URL=nats://localhost:4222
NATS_USERNAME=nats
NATS_PASSWORD=change_me

HEARTBEAT_INTERVAL_SEC=5

# ⚠️ کلید مشترک HMAC پلتفرم برای تأیید اصالت دستورهای deploy. باید دقیقاً با
# SERVICE_HMAC_SECRET در botmanager و apimanager یکسان باشد؛ خالی‌گذاشتن یعنی
# agentmanager بالا نمی‌آید (fail-closed) چون نمی‌تواند دستورها را تأیید کند.
SERVICE_HMAC_SECRET=change_me_shared_platform_hmac_secret

# ── امنیت و محدودیت منابع container ها ──
# (۲۰۲۶-۰۷-۰۴) whitelist محلی (ALLOWED_IMAGES) حذف شد — حالا از سرویس مرکزی
# image-registry پرسیده می‌شود. آدرس HTTP آن سرویس را این‌جا بگذارید؛ خالی
# گذاشتن یعنی هیچ image ای مجاز نیست (fail-closed).
IMAGE_REGISTRY_URL=http://localhost:8100
IMAGE_REGISTRY_TIMEOUT_SEC=5

# پیش‌فرض‌های منابع (per-deploy از طریق DeployCommand.Settings قابل override است)
DEFAULT_MEMORY_MB=512
DEFAULT_CPUS=1.0
DEFAULT_PIDS_LIMIT=256
# فایل‌سیستم ریشه فقط‌خواندنی (سخت‌گیرانه). برای bot هایی که روی دیسک می‌نویسند false کنید.
READONLY_ROOTFS=true
DEFAULT_TMPFS_MB=64

# ── env پایه‌ی containerهای deploy شده ──
# فایل KEY=VALUE با آدرس‌های زیرساخت این سرور (Mongo/NATS/Redis/Postgres +
# secret ها) که به env هر container تزریق می‌شود. botmanager فقط env مخصوص
# app (BOT_TOKEN, INSTANCE_ID, ...) را از NATS می‌فرستد؛ اتصال‌ها لوکال‌اند.
# این فایل secret دارد و در .gitignore است — روی هر سرور جدا ساخته شود.
BOT_BASE_ENV_FILE=./botenv.env
# دایرکتوری با فایل‌های per-service-type: uploader.env, vpn-bot.env, archive-bot.env
# هر فایل فقط مقادیر اختصاصی آن service type را دارد (DSN مخصوص، REDIS_DB، ...).
# روی BaseEnv اعمال می‌شوند؛ cmd.EnvVars همیشه برنده است. در .gitignore است.
BOT_ENV_DIR=./botenv
# شبکه‌ی داکری که container ها به آن وصل می‌شوند تا اسم‌های nats/mongodb/...
# را ببینند (شبکه‌ی همان compose ای که زیرساخت را اجرا می‌کند).
DEFAULT_NETWORK=deploy_backend

# اختیاری — اگر خالی باشد Docker SDK به‌صورت خودکار از unix:///var/run/docker.sock
# استفاده می‌کند. این متغیر جزو Config برنامه نیست (مستقیم توسط Docker SDK
# خوانده می‌شود، رجوع dockerclient.FromEnv در internal/docker/client.go)، ولی
# در docker-compose معمولاً به docker-socket-proxy اشاره می‌کند.
# DOCKER_HOST=tcp://docker-socket-proxy:2375
