SERVER_ID=cbe9f282-06a4-4c23-83b2-fe52b8ff9e17

# ⚠️ این مقادیر باید با NATS_USERNAME/NATS_PASSWORD در .env ریشه یکی بمانند.
# نکته: در اجرای docker-compose، این دو خط override می‌شوند (environment:
# در docker-compose.yml) — فقط برای اجرای محلی/مستقیم لازم‌اند.
NATS_URL=nats://localhost:4222
NATS_USERNAME=nats
NATS_PASSWORD=nats_secret

HEARTBEAT_INTERVAL_SEC=5

# ── امنیت و محدودیت منابع container ها ──
# whitelist اجباری: فقط image هایی با این prefix ها اجازه‌ی اجرا دارند (جداشده با کاما).
# خالی گذاشتن = هیچ deploy ای مجاز نیست. هیچ image ای از اینترنت pull نمی‌شود؛
# image باید از قبل روی همین سرور موجود باشد.
ALLOWED_IMAGES=creatorbot/,registry.local/creatorbot/

# پیش‌فرض‌های منابع (per-deploy از طریق DeployCommand.Settings قابل override است)
DEFAULT_MEMORY_MB=512
DEFAULT_CPUS=1.0
DEFAULT_PIDS_LIMIT=256
# فایل‌سیستم ریشه فقط‌خواندنی (سخت‌گیرانه). برای bot هایی که روی دیسک می‌نویسند false کنید.
READONLY_ROOTFS=true
DEFAULT_TMPFS_MB=64
