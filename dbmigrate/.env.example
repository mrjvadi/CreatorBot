# DSN از فلگ -dsn یا env POSTGRES_DSN خوانده می‌شود؛ اسم دیتابیس داخل آن
# مهم نیست — dbmigrate برای هر سرویس نام دیتابیس واقعی‌اش را از
# internal/migrate/registry.go می‌گیرد و همان بخش را در DSN جایگزین می‌کند.
POSTGRES_DSN=postgres://botuser:change_me_strong_password@127.0.0.1:5434/postgres?sslmode=disable
